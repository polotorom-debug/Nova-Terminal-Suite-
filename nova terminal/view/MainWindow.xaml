<Window x:Class="NovaConsole.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Console" 
        Height="700" 
        Width="1200"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        Opacity="0.98">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource TabBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Height="35">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🚀 Nova Console" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Content="−" Width="35" Height="35" Style="{StaticResource NovaButtonStyle}" Click="MinimizeWindow"/>
                    <Button Content="□" Width="35" Height="35" Style="{StaticResource NovaButtonStyle}" Click="MaximizeWindow"/>
                    <Button Content="✕" Width="35" Height="35" Style="{StaticResource NovaButtonStyle}" Background="#E81123" Click="CloseWindow"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Grid.Column="0" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tabs -->
            <Grid Grid.Row="0" Background="{StaticResource TabBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Height="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0" 
                           ItemsSource="{Binding Tabs}" 
                           SelectedIndex="{Binding SelectedTabIndex}"
                           Background="Transparent"
                           BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Background="{StaticResource TabBrush}" 
                                               BorderBrush="{StaticResource BorderBrush}" 
                                               BorderThickness="0,0,1,0"
                                               Padding="15,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{TemplateBinding Content}"/>
                                                <Button Grid.Column="1" 
                                                       Content="✕" 
                                                       Margin="10,0,0,0"
                                                       Width="20"
                                                       Height="20"
                                                       Style="{StaticResource NovaButtonStyle}"
                                                       Background="{StaticResource AccentBrush}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.ItemContainerStyle>
                </TabControl>

                <Button Grid.Column="1" Content="➕ Nueva Tab" Command="{Binding AddTab}" Margin="5" Style="{StaticResource NovaButtonStyle}" Padding="10,5" FontSize="10"/>
            </Grid>

            <!-- Console Output -->
            <RichTextBox Grid.Row="1" 
                        x:Name="ConsoleOutput"
                        Style="{StaticResource ConsoleRichTextBoxStyle}"
                        Margin="10"
                        VerticalScrollBarVisibility="Auto"/>

            <!-- Input Area -->
            <Grid Grid.Row="2" Background="{StaticResource TabBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="❯ " FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource ConsoleBrush}"/>

                <TextBox Grid.Column="1" 
                        x:Name="InputBox"
                        Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource ConsoleTextBoxStyle}"
                        Margin="5,0"
                        KeyDown="InputBox_KeyDown"/>

                <Button Grid.Column="2" 
                       Content="Ejecutar" 
                       Command="{Binding ExecuteCommand}"
                       Style="{StaticResource NovaButtonStyle}"/>
            </Grid>
        </Grid>

        <!-- System Panel -->
        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <StackPanel Padding="15">
                <!-- System Info Title -->
                <TextBlock Text="🖥️ SISTEMA" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>

                <!-- CPU Usage -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="CPU" Foreground="{StaticResource ForegroundBrush}"/>
                    <Grid Height="20" Background="{StaticResource BackgroundBrush}" CornerRadius="3" Margin="0,5">
                        <Rectangle Fill="{StaticResource AccentBrush}" Width="{Binding CpuUsage, StringFormat='{}{0}%', Converter={StaticResource WidthConverter}}" HorizontalAlignment="Left"/>
                    </Grid>
                    <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource ConsoleBrush}" FontSize="10"/>
                </StackPanel>

                <!-- RAM Usage -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="RAM" Foreground="{StaticResource ForegroundBrush}"/>
                    <Grid Height="20" Background="{StaticResource BackgroundBrush}" CornerRadius="3" Margin="0,5">
                        <Rectangle Fill="{StaticResource ConsoleBrush}" Width="{Binding RamUsage, StringFormat='{}{0}%', Converter={StaticResource WidthConverter}}" HorizontalAlignment="Left"/>
                    </Grid>
                    <TextBlock Text="{Binding RamUsage, StringFormat='{}{0:F1}%'}" Foreground="{StaticResource ConsoleBrush}" FontSize="10"/>
                </StackPanel>

                <!-- Commands -->
                <TextBlock Text="📋 ACCESOS RÁPIDOS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,20,0,10"/>

                <Button Content="🔄 Limpiar" Command="{Binding ClearConsole}" Style="{StaticResource NovaButtonStyle}" Width="200" Margin="0,0,0,5" HorizontalAlignment="Left"/>
                <Button Content="💾 Historial" Style="{StaticResource NovaButtonStyle}" Width="200" Margin="0,0,0,5" HorizontalAlignment="Left"/>
                <Button Content="⚙️ Configuración" Style="{StaticResource NovaButtonStyle}" Width="200" Margin="0,0,0,5" HorizontalAlignment="Left"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>