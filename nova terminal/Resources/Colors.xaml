<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors -->
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="ForegroundColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="ConsoleGreen">#00FF00</Color>
    <Color x:Key="ConsoleText">#E0E0E0</Color>
    <Color x:Key="TabBackground">#252526</Color>
    <Color x:Key="PanelBackground">#2D2D2D</Color>
    <Color x:Key="BorderColor">#3E3E42</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="ConsoleBrush" Color="#00FF00"/>
    <SolidColorBrush x:Key="TabBrush" Color="#252526"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>

</ResourceDictionary>